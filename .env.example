# --- DeepSeek (quality gate + ingest via claude-agent-sdk) ---
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# --- claude-agent-sdk pointed at DeepSeek ---
ANTHROPIC_BASE_URL=https://api.deepseek.com/v1/antropic
ANTHROPIC_AUTH_TOKEN=sk-...
CLAUDE_AGENT_PRO_MODEL=deepseek-v4-pro
CLAUDE_AGENT_SMALL_MODEL=deepseek-v4-flash

# --- Telegram (MVP: set when implementing Phase 6) ---
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=123456789,987654321
OWNER_CHAT_ID=123456789

# --- Paths ---
# In Docker these are set inside the container by docker-compose
# (KB_ROOT=/wiki, STATE_DB=/data/state.db). Override here only for local dev.
KB_ROOT=/Users/nikita.vakhrameev/Projects/llm-kb-wiki
STATE_DB=/Users/nikita.vakhrameev/Projects/llm-kb/state.db

# --- Docker deployment (read by docker-compose.yml) ---
# IMAGE          full image ref pulled by `docker compose pull`, e.g.
#                ghcr.io/<owner>/llm-kb:sha-<commit>
# STATE_DB_DIR   host directory containing state.db (mounted at /data)
# WIKI_DIR       host path to llm-kb-wiki repo (mounted at /wiki)
IMAGE=
STATE_DB_DIR=./data
WIKI_DIR=./llm-kb-wiki

# --- Tuning ---
POLL_INTERVAL_SECONDS=2
GATE_ACCEPT_THRESHOLD=60
INGEST_TIMEOUT_SECONDS=600
INGEST_MAX_TURNS=25
LINT_MAX_TURNS=40
SYNTHESIS_MAX_TURNS=60
RETRIES_MAX=3
RETRY_BACKOFF_BASE_SECONDS=60
SWEEPER_STUCK_MINUTES=30

# --- Cron ---
LINT_HOUR=2
LINT_MINUTE=0
SYNTHESIS_DAY=sun
SYNTHESIS_HOUR=9
SYNTHESIS_MINUTE=0
TZ=Europe/Berlin

# --- Git ---
# Automatically push to origin after each successful ingest.
KB_GIT_AUTOPUSH=false
# Private SSH key in base64 format for authenticated git pull/push (content, not path).
# Use when the remote requires SSH authentication (e.g. GitHub deploy keys).
KB_GIT_SSH_KEY=
